    <plurals name="permissions_details_flags_more_label">
        <item quantity="other">+%d개 더</item>
    </plurals>
    <!-- Permission details help dialog -->
    <string name="permissions_details_help_title">권한 표시기</string>
    <string name="permissions_details_help_section_protection">보호 유형</string>
    <string name="permissions_details_help_dangerous">위험 — 런타임에서 명시적인 사용자 승인이 필요합니다. 민감한 데이터나 기기 기능에 접근할 수 있습니다.</string>
    <string name="permissions_details_help_normal">일반 — 설치 시 자동으로 부여됩니다. 다른 앱이나 시스템에 미치는 위험이 없습니다.</string>
    <string name="permissions_details_help_signature">서명 — 권한을 선언한 앱과 동일한 인증서로 서명된 앱에만 부여됩니다.</string>
    <string name="permissions_details_help_internal">내부 — Android 시스템 내부용으로 예약되어 있습니다. 제3자 앱에서 사용할 수 없습니다.</string>
    <string name="permissions_details_help_section_tags">권한 태그</string>
    <string name="permissions_details_help_tag_runtime">런타임 — 앱이 이 권한을 사용하기 전에 허락을 요청해야 합니다.</string>
    <string name="permissions_details_help_tag_install_time">설치 시 — 앱이 설치될 때 자동으로 부여됩니다.</string>
    <string name="permissions_details_help_tag_special_access">특수 접근 — 시스템 설정에서 스위치를 켜야 합니다.</string>
    <string name="permissions_details_help_tag_documented">문서화됨 — 공식 Android 매니페스트 문서에 나열되어 있습니다.</string>
    <string name="permissions_details_help_tag_notable">주목할 만한 — 개인 정보 또는 보안에 대한 영향으로 특히 주목해야 합니다.</string>
    <string name="permissions_details_help_tag_non_standard">비표준 — 표준 Android 권한 세트에 포함되지 않습니다. 제3자 앱 또는 OEM이 선언한 권한입니다.</string>
    <string name="permissions_details_status_help_title">상태 표시기</string>
    <string name="permissions_details_help_section_status">부여 상태</string>
    <string name="permissions_details_help_status_granted">허용됨 — 앱에 이 권한이 부여되었습니다.</string>
    <string name="permissions_details_help_status_in_use">사용 중 — 부여되었으며 현재 앱에서 적극적으로 사용 중입니다.</string>
    <string name="permissions_details_help_status_denied">거부됨 — 앱이 이 권한을 요청했지만 부여되지 않았습니다.</string>
    <string name="permissions_details_help_status_unknown">알 수 없음 — 부여 상태를 확인할 수 없습니다. 예: 다른 사용자 프로필의 앱.</string>
    <string name="permissions_details_help_section_badges">배지</string>
    <string name="permissions_details_help_system_badge">시스템 — 미리 설치된 시스템 앱입니다.</string>
    <string name="permission_nfc_label">NFC</string>
    <string name="permission_nfc_description">앱이 근거리 무선 통신(NFC) 태그, 카드 및 리더와 통신할 수 있도록 허용합니다.</string>
    <string name="permission_manage_media_label">미디어 관리</string>
    <string name="permission_manage_media_description">앱이 다른 앱으로 만든 미디어 파일을 사용자에게 묻지 않고 수정하거나 삭제할 수 있도록 허용합니다. 앱은 파일과 미디어에 액세스할 권한이 있어야 합니다.</string>
    <string name="permission_usage_data_access_label">사용 데이터 액세스</string>
    <string name="permission_usage_data_access_description">앱이 다른 어떤 앱을 얼마나 자주 사용하는지 추적하고, 서비스 제공업체, 언어 설정 및 기타 사용 데이터를 식별할 수 있도록 허용합니다.</string>
    <string name="permission_modify_system_settings_label">시스템 설정 수정</string>
    <string name="permission_modify_system_settings_description">앱이 시스템 설정 데이터를 수정할 수 있도록 허용합니다. 악의적인 앱은 시스템 구성을 손상시킬 수 있습니다.</string>
    <string name="permission_bluetooth_advertise_label">Bluetooth 광고</string>
    <string name="permission_bluetooth_advertise_description">앱이 근처 Bluetooth 기기에 광고할 수 있도록 허용합니다.</string>
    <string name="permission_get_accounts_label">계정 가져오기</string>
    <string name="permission_get_accounts_description">앱이 기기에 등록된 계정 목록을 확인할 수 있도록 허용합니다. 여기에는 설치한 앱이 생성한 계정도 포함될 수 있습니다.</string>
    <string name="permission_access_background_location_label">백그라운드 위치 액세스</string>
    <string name="permission_access_background_location_description">앱이 사용 중이지 않을 때에도 언제든지 위치에 액세스할 수 있도록 허용합니다.</string>
    <string name="permission_access_media_location_label">미디어 위치 액세스</string>
    <string name="permission_access_media_location_description">앱이 미디어 컬렉션에서 위치를 읽을 수 있도록 허용합니다.</string>
    <string name="permission_manage_accounts_label">계정 관리</string>
    <string name="permission_manage_accounts_description">앱이 기기의 계정을 관리할 수 있도록 허용합니다.</string>
    <string name="permission_wifi_control_label">WiFi 제어</string>
    <string name="permission_wifi_control_description">앱이 WiFi를 켜거나 끄고, WiFi 네트워크를 스캔하고 연결하며, 네트워크를 추가하거나 제거하거나, 로컬 전용 핫스팟을 시작할 수 있도록 허용합니다.</string>
    <string name="permission_change_network_state_label">네트워크 상태 변경</string>
    <string name="permission_change_network_state_description">앱이 네트워크 연결 상태를 변경할 수 있도록 허용합니다.</string>
    <string name="permission_read_sync_settings_label">동기화 설정 읽기</string>
    <string name="permission_read_sync_settings_description">앱이 계정의 동기화 설정을 읽을 수 있도록 허용합니다.</string>
    <string name="permission_install_unknown_apps_label">알 수 없는 앱 설치 (알 수 없는 소스)</string>
    <string name="permission_install_unknown_apps_description">앱이 기기에 다른 앱을 수동으로 설치할 수 있도록 허용합니다. 기기와 데이터가 위험에 처할 수 있습니다.</string>
    <string name="permission_all_files_access_label">모든 파일 액세스</string>
    <string name="permission_all_files_access_description">앱이 기기의 모든 파일과 연결된 모든 저장 장치를 읽고, 수정하고, 삭제할 수 있도록 허용합니다. 이 권한을 가진 앱은 사용자에게 알리지 않고 앱과 관련이 없는 파일에도 액세스할 수 있습니다.</string>
    <string name="permission_appear_on_top_label">맨 위에 표시</string>
    <string name="permission_appear_on_top_description">앱이 사용 중인 다른 앱 위에 항목을 표시할 수 있도록 허용합니다(광고 표시 포함). 이는 다른 앱 사용을 방해할 수 있습니다.</string>
    <string name="permission_files_and_media_label">파일 및 미디어</string>
    <string name="permission_files_and_media_description">앱이 기기의 파일과 미디어에 액세스할 수 있도록 허용합니다.</string>
    <string name="permission_access_to_media_only_label">미디어만 액세스</string>
    <string name="permission_access_to_media_only_description">앱이 기기의 미디어에만 액세스할 수 있도록 허용합니다.</string>
    <string name="permission_access_precise_location_label">정확한/정밀한 위치 액세스</string>
    <string name="permission_access_precise_location_description">앱이 기기의 정확한/정밀한 위치에 액세스할 수 있도록 허용합니다. 이는 대부분의 앱에는 권장되지 않습니다(지도, 택시 서비스, 내 기기 찾기와 같은 기기 추적 서비스 등 일부 앱 제외).</string>
    <string name="permission_access_approximate_location_label">대략적인 위치 액세스</string>
    <string name="permission_access_approximate_location_description">앱이 기기의 대략적인 위치에 액세스할 수 있도록 허용합니다. 이 권한은 핵심 기능을 위해 위치 액세스가 필요한 대부분의 앱에 충분합니다.</string>
    <string name="permission_ignore_battery_optimizations_label">배터리 최적화 무시</string>
    <string name="permission_ignore_battery_optimizations_description">앱이 백그라운드에서 방해받지 않고 실행될 수 있도록 허용합니다. 이는 배터리를 소모할 수 있습니다. 지속적/빈번한 백업 및/또는 동기화를 수행하는 앱(예: Google 포토), 매우 자주 사용되는 앱(예: 이메일, 채팅, SMS 등), 지속적인 알림이 있는 앱에만 권장됩니다.</string>
    <string name="permission_notification_access_label">알림 액세스</string>
    <string name="permission_notification_access_description">앱이 개인 정보(연락처 이름 및 수신한 메시지 텍스트 등)를 포함한 모든 알림을 읽고, 알림을 다시 알림하거나 해제하거나, 포함된 작업 버튼을 트리거하고(전화 응답, SMS/이메일 삭제 등), 방해 금지 모드(DND)를 켜거나 끄고 관련 설정을 변경할 수 있도록 허용합니다.</string>
    <string name="permission_do_not_disturb_permission_label">방해 금지 모드(DND) 권한</string>
    <string name="permission_do_not_disturb_permission_description">앱이 방해 금지 모드(DND)를 켜거나 끄고 관련 설정을 변경할 수 있도록 허용합니다.</string>
    <string name="permission_alarms_and_reminders_label">알람 및 미리 알림</string>
    <string name="permission_alarms_and_reminders_description">앱이 알람을 설정하고 시간에 민감한 작업을 예약할 수 있도록 허용합니다. 이를 통해 앱이 백그라운드에서 실행될 수 있으며, 더 많은 배터리를 사용할 수 있습니다. 앱에 대해 이 권한을 끄면 해당 특정 앱에서 예약한 기존 알람과 시간 기반 이벤트가 작동하지 않게 됩니다.</string>
    <string name="permission_turn_screen_on_label">화면 켜기</string>
    <string name="permission_turn_screen_on_description">알람이나 수신 전화와 같이 주의가 필요할 때 앱이 기기 화면을 켤 수 있도록 허용합니다.</string>
    <string name="permission_full_screen_intent_label">전체 화면 알림</string>
    <string name="permission_full_screen_intent_description">기기가 잠겨 있거나 사용 중일 때 화면을 차지하는 전체 화면 알림을 앱이 표시할 수 있도록 허용합니다. 일반적으로 알람, 전화 및 기타 시간에 민감한 이벤트에 사용됩니다.</string>
    <string name="permission_interact_across_profiles_label">연결된 업무용 및 개인 앱</string>
    <string name="permission_interact_across_profiles_description">앱이 업무용 프로필과 개인 프로필 간에 통신하여 프로필 경계를 넘어 데이터와 기능을 공유할 수 있도록 허용합니다.</string>
    <string name="permission_loader_usage_stats_label">로더 사용 통계</string>
    <string name="permission_loader_usage_stats_description">앱이 기기에서 데이터 로더 사용에 대한 통계를 수집할 수 있도록 허용합니다.</string>
    <string name="permission_premium_sms_services_label">프리미엄 SMS 액세스</string>
    <string name="permission_premium_sms_services_description">앱이 프리미엄 문자 메시지 서비스를 사용할 수 있도록 허용합니다. 이는 비용이 발생합니다.</string>
    <string name="permission_unlimited_data_access_label">무제한 데이터 액세스</string>
    <string name="permission_unlimited_data_access_description">앱이 무제한 데이터에 액세스할 수 있도록 허용합니다. 데이터 절약 모드가 켜져 있을 때도 앱이 데이터를 소비할 수 있습니다.</string>
    <string name="permission_group_calendar_label">캘린더</string>
    <string name="permission_group_calendar_description"><![CDATA[캘린더 관련 권한, 예: 항목 보기 및 편집.]]></string>
    <string name="permission_group_files_label">파일 및 미디어</string>
    <string name="permission_group_files_description">파일 관련 권한. 저장소, 문서 및 미디어 액세스.</string>
    <string name="permission_group_other_label">기타</string>
    <string name="permission_group_other_description">특정 카테고리가 없는 기타 권한.</string>
    <string name="permission_group_messaging_label">메시징</string>
    <string name="permission_group_messaging_description">SMS, MMS 등. 메시징과 관련된 모든 것.</string>
    <string name="permission_group_connectivity_label">연결성</string>
    <string name="permission_group_connectivity_description">WiFi, LTE, Bluetooth 등. 외부 세계와의 통신과 관련된 권한.</string>
    <string name="permission_group_sensors_label">센서</string>
    <string name="permission_group_sensors_description">가속도계, 자이로스코프, 신체 센서, 활동 인식 등. 기기가 입력을 캡처할 수 있는 방법.</string>
    <string name="permission_group_calls_label">통화</string>
    <string name="permission_group_calls_description">통화 관련 권한</string>
    <string name="permission_group_location_label">위치</string>
    <string name="permission_group_location_description">위치 관련 권한.</string>
    <string name="permission_group_contacts_label">연락처</string>
    <string name="permission_group_contacts_description">"연락처 읽기 및 쓰기."</string>
    <string name="permission_group_apps_label">앱</string>
    <string name="permission_group_apps_description">명시적인 사용자 동의가 필요한 특별 액세스 권한.</string>
    <string name="permission_group_battery_label">배터리</string>
    <string name="permission_group_battery_description">배터리 관련 권한.</string>
    <string name="permission_group_camera_label">카메라</string>
    <string name="permission_group_camera_description">카메라 관련 권한.</string>
    <string name="permission_group_audio_label">마이크</string>
    <string name="permission_group_audio_description">마이크 관련 권한.</string>
    <string name="permissions_list_empty_message">표시할 권한이 없습니다.</string>
    <string name="permissions_list_empty_search_message">검색에 일치하는 권한이 없습니다.</string>
    <string name="permission_picture_in_picture_label">화면 속 화면</string>
    <string name="permission_legacy_storage_label">레거시 저장소</string>
    <string name="permission_legacy_storage_description">앱이 범위별 저장소 제한 없이 외부 저장소에 접근할 수 있도록 허용합니다. Android 10 이전의 기본 동작이었습니다. 이 접근 권한이 있는 앱은 공유 저장소 어디서나 파일을 읽고 쓸 수 있습니다.</string>
