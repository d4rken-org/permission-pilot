    <string name="overview_section_profile_label">프로필</string>
    <string name="overview_section_install_source_label">설치 소스</string>
    <string name="overview_section_privacy_label">개인 정보</string>
    <string name="overview_section_security_label">보안</string>
    <string name="overview_section_manifest_label">매니페스트</string>
    <string name="overview_summary_apps_manifest_flags_label">앱 검색 가능</string>
    <string name="overview_section_system_label">기기 테마 사용</string>
