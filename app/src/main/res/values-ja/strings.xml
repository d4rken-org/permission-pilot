    <string name="permission_nfc_label">NFC</string>
    <string name="permission_nfc_description">アプリが近距離無線通信（NFC）タグ、カード、リーダーと通信することを許可します。</string>
    <string name="permission_manage_media_label">メディア管理</string>
    <string name="permission_manage_media_description">アプリが他のアプリで作成されたメディアファイルを許可なしに変更または削除することを許可します。アプリはファイルとメディアへのアクセス権限を持つ必要があります。</string>
    <string name="permission_usage_data_access_label">使用データアクセス</string>
    <string name="permission_usage_data_access_description">アプリが他のどのアプリを使用しているか、どのくらいの頻度で使用しているかを追跡し、サービスプロバイダー、言語設定、その他の使用データを識別することを許可します。</string>
    <string name="permission_modify_system_settings_label">システム設定の変更</string>
    <string name="permission_modify_system_settings_description">アプリがシステムの設定データを変更することを許可します。悪意のあるアプリはシステムの構成を破損させる可能性があります。</string>
    <string name="permission_bluetooth_advertise_label">Bluetooth広告</string>
    <string name="permission_bluetooth_advertise_description">アプリが近くのBluetoothデバイスに広告することを許可します。</string>
    <string name="permission_get_accounts_label">アカウントの取得</string>
    <string name="permission_get_accounts_description">アプリがデバイスに登録されているアカウントのリストを取得できるようになります。インストール済みのアプリが作成したアカウントも含まれる場合があります。</string>
    <string name="permission_access_background_location_label">バックグラウンド位置アクセス</string>
    <string name="permission_access_background_location_description">アプリが使用されていない時でも、いつでも位置にアクセスすることを許可します。</string>
    <string name="permission_access_media_location_label">メディア位置アクセス</string>
    <string name="permission_access_media_location_description">アプリがメディアコレクションから位置を読み取ることを許可します。</string>
    <string name="permission_manage_accounts_label">アカウント管理</string>
    <string name="permission_manage_accounts_description">アプリがデバイス内のアカウントを管理することを許可します。</string>
    <string name="permission_wifi_control_label">WiFi制御</string>
    <string name="permission_wifi_control_description">アプリがWiFiをオン・オフにし、WiFiネットワークをスキャンして接続し、ネットワークを追加・削除し、ローカル専用ホットスポットを開始することを許可します。</string>
    <string name="permission_change_network_state_label">ネットワーク状態の変更</string>
    <string name="permission_change_network_state_description">アプリがネットワーク接続の状態を変更することを許可します。</string>
    <string name="permission_read_sync_settings_label">同期設定の読み取り</string>
    <string name="permission_read_sync_settings_description">アプリがアカウントの同期設定を読み取ることを許可します。</string>
    <string name="permission_install_unknown_apps_label">不明なアプリのインストール（不明な提供元）</string>
    <string name="permission_install_unknown_apps_description">アプリがデバイスに他のアプリを手動でインストールすることを許可します。これによりデバイスとデータが危険にさらされる可能性があります。</string>
    <string name="permission_all_files_access_label">すべてのファイルへのアクセス</string>
    <string name="permission_all_files_access_description">アプリがデバイス上のすべてのファイルと接続されたストレージデバイスを読み取り、変更、削除することを許可します。この権限を持つアプリは、通知なしにアプリに関連しないファイルにもアクセスできます。</string>
    <string name="permission_appear_on_top_label">他のアプリの上に表示</string>
    <string name="permission_appear_on_top_description">アプリが使用中の他のアプリの上に物を表示すること（広告表示を含む）を許可します。これは他のアプリの使用を妨げる可能性があります。</string>
    <string name="permission_files_and_media_label">ファイルとメディア</string>
    <string name="permission_files_and_media_description">アプリがデバイス上のファイルとメディアにアクセスすることを許可します。</string>
    <string name="permission_access_to_media_only_label">メディアのみへのアクセス</string>
    <string name="permission_access_to_media_only_description">アプリがデバイス上のメディアのみにアクセスすることを許可します。</string>
    <string name="permission_access_precise_location_label">正確・精密な位置へのアクセス</string>
    <string name="permission_access_precise_location_description">アプリがデバイスの正確・精密な位置にアクセスすることを許可します。これは大部分のアプリには推奨されません（マップ、タクシーサービス、Find My Deviceなどのデバイス追跡サービスなどの一部のアプリを除く）。</string>
    <string name="permission_access_approximate_location_label">おおよその位置へのアクセス</string>
    <string name="permission_access_approximate_location_description">アプリがデバイスのおおよその位置にアクセスすることを許可します。この権限は、コア機能のために位置アクセスが必要な大部分のアプリには十分です。</string>
    <string name="permission_ignore_battery_optimizations_label">バッテリー最適化を無視</string>
    <string name="permission_ignore_battery_optimizations_description">アプリがバックグラウンドで妨げられることなく実行することを許可します。これはバッテリーを消耗させる可能性があります。継続的・頻繁なバックアップ・同期を実行するアプリ（Google フォトなど）、非常に頻繁に使用されるアプリ（メール、チャット、SMSなど）、および永続的な通知を持つアプリにのみ推奨されます。</string>
    <string name="permission_notification_access_label">通知アクセス</string>
    <string name="permission_notification_access_description">アプリがすべての通知を読み取ること（連絡先名や受信メッセージのテキストなどの個人情報を含む）、通知をスヌーズ・無視すること、または含まれるアクションボタンをトリガーすること（電話に応答、SMS・メールの削除など）、およびおやすみモード（DND）をオン・オフし、関連設定を変更することを許可します。</string>
    <string name="permission_do_not_disturb_permission_label">おやすみモード（DND）権限</string>
    <string name="permission_do_not_disturb_permission_description">アプリがおやすみモード（DND）をオン・オフし、関連設定を変更することを許可します。</string>
    <string name="permission_alarms_and_reminders_label">アラームとリマインダー</string>
    <string name="permission_alarms_and_reminders_description">アプリがアラームを設定し、時間に敏感なアクションをスケジュールすることを許可します。これによりアプリがバックグラウンドで実行され、より多くのバッテリーを使用する可能性があります。アプリでこの権限をオフにすると、その特定のアプリによってスケジュールされた既存のアラームと時間ベースのイベントが機能しなくなります。</string>
    <string name="permission_turn_screen_on_label">画面をオンにする</string>
    <string name="permission_turn_screen_on_description">アラームや着信など、注意が必要な時にアプリがデバイスの画面をオンにすることを許可します。</string>
    <string name="permission_full_screen_intent_label">フルスクリーン通知</string>
    <string name="permission_full_screen_intent_description">デバイスがロックされている時や使用中に画面を占有するフルスクリーン通知をアプリが表示することを許可します。一般的にアラーム、電話、その他の時間に敏感なイベントに使用されます。</string>
    <string name="permission_interact_across_profiles_label">接続された仕事用と個人用アプリ</string>
    <string name="permission_interact_across_profiles_description">アプリが仕事用プロファイルと個人用プロファイル間で通信し、プロファイルの境界を越えてデータと機能を共有することを許可します。</string>
    <string name="permission_loader_usage_stats_label">ローダー使用統計</string>
    <string name="permission_loader_usage_stats_description">アプリがデバイス上のデータローダー使用に関する統計を収集することを許可します。</string>
    <string name="permission_premium_sms_services_label">プレミアムSMSアクセス</string>
    <string name="permission_premium_sms_services_description">アプリがプレミアムテキストメッセージサービスを使用することを許可します。これはお金がかかります。</string>
    <string name="permission_unlimited_data_access_label">無制限データアクセス</string>
    <string name="permission_unlimited_data_access_description">アプリが無制限のデータにアクセスすることを許可します。データセーバーがオンの時でもアプリはデータを消費できます。</string>
    <string name="permission_group_calendar_label">カレンダー</string>
    <string name="permission_group_calendar_description"><![CDATA[カレンダー関連の権限、例：エントリの表示と編集。]]></string>
    <string name="permission_group_files_label">ファイルとメディア</string>
    <string name="permission_group_files_description">ファイル関連の権限。ストレージ、ドキュメント、メディアへのアクセス。</string>
    <string name="permission_group_other_label">その他</string>
    <string name="permission_group_other_description">特定のカテゴリなしのその他の権限。</string>
    <string name="permission_group_messaging_label">メッセージング</string>
    <string name="permission_group_messaging_description">SMS、MMSなど。メッセージング関連のすべて。</string>
    <string name="permission_group_connectivity_label">接続</string>
    <string name="permission_group_connectivity_description">WiFi、LTE、Bluetoothなど。外界との通信に関連する権限。</string>
    <string name="permission_group_sensors_label">センサー</string>
    <string name="permission_group_sensors_description">加速度計、ジャイロ、ボディセンサー、アクティビティ認識など。デバイスが入力をキャプチャする方法。</string>
