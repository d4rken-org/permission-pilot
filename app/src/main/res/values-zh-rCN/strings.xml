    <string name="permissions_details_help_title">权限指示器</string>
    <string name="permissions_details_help_section_protection">保护级别</string>
    <string name="permissions_details_help_dangerous">危险——运行时需要用户明确授权。可访问敏感数据或设备功能。</string>
    <string name="permissions_details_help_normal">普通——安装时自动授予。对其他应用或系统风险极小。</string>
    <string name="permissions_details_help_signature">签名——仅授予与声明该权限的应用使用相同证书签名的应用。</string>
    <string name="permissions_details_help_internal">内部——为安卓系统内部保留。第三方应用无法使用。</string>
    <string name="permissions_details_help_section_tags">权限标签</string>
    <string name="permissions_details_help_tag_runtime">运行时权限——应用必须在使用此权限前向您请求。</string>
    <string name="permissions_details_help_tag_install_time">安装时权限——应用安装时自动授予。</string>
    <string name="permissions_details_help_tag_special_access">特殊访问权限——需要在系统设置中手动打开开关。</string>
    <string name="permissions_details_help_tag_documented">已记录——已列入官方 Android 清单文档。</string>
    <string name="permissions_details_help_tag_notable">值得关注——因其对隐私或安全的影响而特别引人注目。</string>
    <string name="permissions_details_help_tag_non_standard">非标准——不属于标准 Android 权限集，由第三方应用或 OEM 声明。</string>
    <string name="permissions_details_status_help_title">状态指示器</string>
    <string name="permissions_details_help_section_status">授权状态</string>
    <string name="permissions_details_help_status_granted">已授权——应用已获得此权限。</string>
    <string name="permissions_details_help_status_in_use">使用中——已授权且应用目前正在主动使用。</string>
    <string name="permissions_details_help_status_denied">已拒绝——应用请求了此权限但未获授予。</string>
    <string name="permissions_details_help_status_unknown">未知——无法确定授权状态，例如其他用户配置文件中的应用。</string>
    <string name="permissions_details_help_section_badges">徽章</string>
    <string name="permissions_details_help_system_badge">系统——该应用是预装系统应用。</string>
