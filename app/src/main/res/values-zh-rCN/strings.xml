    <string name="permission_get_accounts_description">允许应用获取设备已知账户列表。这可能包括您已安装的应用创建的任何账户。</string>
    <string name="permission_access_background_location_label">访问后台位置</string>
    <string name="permission_access_background_location_description">允许应用随时访问位置，即使它们未在使用中。</string>
    <string name="permission_access_media_location_label">访问媒体位置</string>
    <string name="permission_access_media_location_description">允许应用从您的媒体集合中读取位置。</string>
    <string name="permission_manage_accounts_label">管理帐户</string>
    <string name="permission_manage_accounts_description">允许应用管理设备上的帐户。</string>
    <string name="permission_wifi_control_label">WiFi 控制</string>
    <string name="permission_wifi_control_description">允许应用打开或关闭 WiFi，扫描和连接 WiFi 网络，添加或删除网络，或启动本地热点。</string>
    <string name="permission_change_network_state_label">更改网络状态</string>
    <string name="permission_change_network_state_description">允许应用更改网络连接状态。</string>
    <string name="permission_read_sync_settings_label">读取同步设置</string>
    <string name="permission_read_sync_settings_description">允许应用读取帐户的同步设置。</string>
    <string name="permission_install_unknown_apps_label">安装未知应用（未知来源）</string>
    <string name="permission_install_unknown_apps_description">允许应用在您的设备上手动安装其他应用。这可能会给您的设备和数据带来风险。</string>
    <string name="permission_all_files_access_label">全部文件访问</string>
    <string name="permission_all_files_access_description">允许应用读取、修改和删除您设备上的所有文件，以及任何连接的存储设备上的文件。具有此权限的应用还可以访问与应用无关的文件，而不通知您。</string>
    <string name="permission_appear_on_top_label">置于顶部</string>
    <string name="permission_appear_on_top_description">允许应用在您正在使用的其他应用之上显示内容（包括显示广告）。这可能会干扰您使用其他应用的体验。</string>
    <string name="permission_files_and_media_label">文件和媒体</string>
    <string name="permission_files_and_media_description">允许应用访问设备上的文件和媒体。</string>
    <string name="permission_access_to_media_only_label">仅访问媒体</string>
    <string name="permission_access_to_media_only_description">允许应用仅访问设备上的媒体。</string>
    <string name="permission_access_precise_location_label">访问精确位置</string>
    <string name="permission_access_precise_location_description">允许应用访问您设备的精确位置。对于大多数应用来说，这是不推荐的（除了一些像地图、打车服务、设备跟踪服务（例如“查找我的设备”等）之类的应用）。</string>
    <string name="permission_access_approximate_location_label">访问大致位置</string>
    <string name="permission_access_approximate_location_description">允许应用访问您设备的大致位置。这个权限对于大多数需要访问位置进行核心功能的应用来说是足够的。</string>
    <string name="permission_ignore_battery_optimizations_label">忽略电池优化</string>
    <string name="permission_ignore_battery_optimizations_description">允许应用在后台无障碍运行。这可能会消耗电池电量。只推荐用于执行持续/频繁备份和/或同步（例如 Google 相册）、非常频繁使用的应用（例如电子邮件、聊天、短信等）以及具有持续通知的应用。</string>
    <string name="permission_notification_access_label">通知访问</string>
    <string name="permission_notification_access_description">允许应用读取您的所有通知，包括个人信息（例如联系人姓名和接收到的消息文本），暂停或解除通知或触发它们包含的操作按钮（例如接听电话、删除短信/电子邮件等），以及打开或关闭免打扰（DND）并更改相关设置。</string>
    <string name="permission_do_not_disturb_permission_label">免打扰（DND）权限</string>
    <string name="permission_do_not_disturb_permission_description">允许应用打开或关闭免打扰（DND）并更改相关设置。</string>
    <string name="permission_alarms_and_reminders_label">闹钟和提醒</string>
    <string name="permission_alarms_and_reminders_description">允许应用设置闹钟和安排与时间敏感的操作。这使应用可以在后台运行，可能会消耗更多的电池电量。对于应用来说，关闭此权限将导致由特定应用安排的现有闹钟和基于时间的事件停止工作。</string>
    <string name="permission_turn_screen_on_label">打开屏幕</string>
    <string name="permission_turn_screen_on_description">允许应用在需要您注意时打开设备屏幕，例如闹钟或来电。</string>
    <string name="permission_full_screen_intent_label">全屏通知</string>
    <string name="permission_full_screen_intent_description">允许应用显示全屏通知，在设备锁定或使用时占据您的屏幕。通常用于闹钟、来电和其他时间敏感事件。</string>
    <string name="permission_interact_across_profiles_label">关联的工作和个人应用</string>
    <string name="permission_interact_across_profiles_description">允许应用在您的工作和个人配置文件之间进行通信，跨配置文件边界共享数据和功能。</string>
    <string name="permission_loader_usage_stats_label">加载器使用统计</string>
    <string name="permission_loader_usage_stats_description">允许应用收集有关设备上数据加载器使用情况的统计信息。</string>
    <string name="permission_premium_sms_services_label">高级短信服务访问</string>
    <string name="permission_premium_sms_services_description">允许应用使用高级短信服务。这将花费您的资金。</string>
    <string name="permission_unlimited_data_access_label">无限数据访问</string>
    <string name="permission_unlimited_data_access_description">允许应用访问无限制的数据。即使数据节省功能已打开，应用也可以使用数据。</string>
