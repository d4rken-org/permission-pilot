    <string name="permission_manage_media_description">允許應用程式修改或刪除其他應用程式所創建的媒體，而無需s取得您的同意。應用程式必須具有取用檔案和媒體的權限。</string>
    <string name="permission_usage_data_access_label">取用使用數據</string>
    <string name="permission_usage_data_access_description">允許應用程式跟蹤您使用的其他應用程式以及使用頻率，識別您的服務提供商、語言設定和其他使用數據。</string>
    <string name="permission_modify_system_settings_label">允許修改系統設定</string>
    <string name="permission_modify_system_settings_description">允許應用程式修改系統的設定數據。惡意程式可能會損壞您的系統設定。</string>
    <string name="permission_bluetooth_advertise_label">藍牙傳播</string>
    <string name="permission_bluetooth_advertise_description">允許應用程式向附近的藍牙設備傳播資訊。</string>
    <string name="permission_get_accounts_label">獲取帳戶</string>
    <string name="permission_get_accounts_description">允許應用程式取得裝置已知帳戶的列表。這可能包括您已安裝的應用程式所建立的任何帳戶。</string>
    <string name="permission_access_background_location_label">一律允許取用位置</string>
    <string name="permission_access_background_location_description">允許應用程式於背景取用位置</string>
    <string name="permission_access_media_location_label">取用媒體位置</string>
    <string name="permission_access_media_location_description">允許應用程式從您的媒體集合中讀取位置。</string>
    <string name="permission_manage_accounts_label">管理帳戶</string>
    <string name="permission_manage_accounts_description">允許應用程式管理設備上的帳戶。</string>
    <string name="permission_wifi_control_label">Wi-Fi 控制</string>
    <string name="permission_wifi_control_description">允許應用程式打開或關閉 Wi-Fi，掃描和連接 Wi-Fi 網路，添加或刪除網路，或啟動本地熱點。</string>
    <string name="permission_change_network_state_label">更改網路狀態</string>
    <string name="permission_change_network_state_description">允許應用程式更改網路連接狀態。</string>
    <string name="permission_read_sync_settings_label">讀取同步設定</string>
    <string name="permission_read_sync_settings_description">允許應用程式讀取帳戶的同步設定。</string>
    <string name="permission_install_unknown_apps_label">安裝未知應用程式（未知來源）</string>
    <string name="permission_install_unknown_apps_description">允許應用程式在您的裝置上手動安裝其他應用程式。這可能會讓您的裝置和資料面臨風險。</string>
    <string name="permission_all_files_access_label">取用所有檔案</string>
    <string name="permission_all_files_access_description">允許應用程式讀取、修改和刪除您設備上所有的檔案，以及任何連接的存儲設備上的檔案。具有此權限的應用程式還可以取用與應用程式無關的檔案而不需您的同意。</string>
    <string name="permission_appear_on_top_label">顯示在其他應用程式上層</string>
    <string name="permission_appear_on_top_description">允許應用程式顯示內容於其他應用程式上層</string>
    <string name="permission_files_and_media_label">檔案和媒體</string>
    <string name="permission_files_and_media_description">允許應用程式取用設備上的檔案和媒體。</string>
    <string name="permission_access_to_media_only_label">僅限於取用媒體</string>
    <string name="permission_access_to_media_only_description">允許應用程式僅限於取用設備上的媒體。</string>
    <string name="permission_access_precise_location_label">取用精確位置</string>
    <string name="permission_access_precise_location_description">允許應用程式取用設備的精確位置。對於大多數應用程式來說，這是不推薦的（除了一些像地圖、打車服務、設備跟蹤服務（例如「查找我的設備」等）應用程式。</string>
    <string name="permission_access_approximate_location_label">取用大致位置</string>
    <string name="permission_access_approximate_location_description">允許應用程式取用設備的大致位置。這個權限對於大多數需要取用位置進行核心功能的應用程式來說是足夠的。</string>
    <string name="permission_ignore_battery_optimizations_label">忽略電池優化</string>
    <string name="permission_ignore_battery_optimizations_description">允許應用程式在後台無障礙運行。這可能會消耗電池電量。只推薦用於執行持續/頻繁備份和/或同步（例如 Google 相簿）、極度頻繁使用的應用程式（例如電子郵件等）以及持續發送通知的應用程式。</string>
    <string name="permission_notification_access_label">通知取用</string>
    <string name="permission_notification_access_description">允許應用程式讀取您的通知。</string>
    <string name="permission_do_not_disturb_permission_label">零打擾（DND）權限</string>
    <string name="permission_do_not_disturb_permission_description">允許應用程式開啟或關閉零打擾（DND）並更改相關設定。</string>
    <string name="permission_alarms_and_reminders_label">鬧鐘和提醒</string>
    <string name="permission_alarms_and_reminders_description">允許應用程式設定鬧鐘和安排與時間管理。這使應用程式能在後台運行並消耗更多的電池電量。</string>
    <string name="permission_turn_screen_on_label">開啟螢幕</string>
    <string name="permission_turn_screen_on_description">允許應用程式在需要您注意時開啟裝置螢幕，例如鬧鐘或來電。</string>
    <string name="permission_full_screen_intent_label">全螢幕通知</string>
    <string name="permission_full_screen_intent_description">允許應用程式顯示全螢幕通知，在裝置鎖定或使用時佔據您的螢幕。通常用於鬧鐘、來電和其他時間敏感事件。</string>
    <string name="permission_interact_across_profiles_label">關聯的工作和個人應用程式</string>
    <string name="permission_interact_across_profiles_description">允許應用程式在您的工作和個人設定檔之間進行通訊，跨設定檔邊界共享資料和功能。</string>
    <string name="permission_loader_usage_stats_label">載入器使用統計</string>
    <string name="permission_loader_usage_stats_description">允許應用程式收集有關裝置上資料載入器使用情況的統計資訊。</string>
    <string name="permission_premium_sms_services_label">SMS 服務取用</string>
    <string name="permission_premium_sms_services_description">允許應用程式使用 SMS 服務。這將收取一些費用。</string>
    <string name="permission_unlimited_data_access_label">無限數據取用</string>
    <string name="permission_unlimited_data_access_description">允許應用程式使用無限制的流量。即使數據節省功能已開啟時仍不受限制。</string>
    <string name="permission_group_calendar_label">日曆</string>
    <string name="permission_group_calendar_description"><![CDATA[與日曆相關的權限，例如查看和編輯項目。]]></string>
    <string name="permission_group_files_label">檔案和媒體</string>
    <string name="permission_group_files_description">與檔案相關的權限。取用存儲、文檔和媒體。</string>
